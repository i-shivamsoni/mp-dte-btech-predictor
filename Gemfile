source "https://rubygems.org"

# GitHub Pages-compatible build. `github-pages` pins Jekyll + the whitelisted
# plugin set so local builds match the deploy build.
gem "jekyll", "~> 4.3"
gem "webrick", "~> 1.8"   # required to `jekyll serve` on Ruby 3+

group :jekyll_plugins do
  gem "jekyll-seo-tag"
end
